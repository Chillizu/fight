{
  "name": "campus-fighting-game",
  "version": "0.7.0",
  "description": "结合知识竞答与格斗对战的本地双人网页游戏",
  "main": "index.html",
  "scripts": {
    "start": "init.bat",
    "server:python": "python -m http.server 8000",
    "server:node": "npx http-server -p 8080 -c-1",
    "verify": "cd tools && python verify_system.py",
    "process:sprites": "cd tools && python sprite_processor.py batch ../assets/sprites/",
    "test:gen": "cd tools && python gen_test_image.py"
  },
  "keywords": ["game", "canvas", "fighting", "education", "ai-generation", "pixel-art", "multiplayer"],
  "author": "Campus Fighting Game Dev Team",
  "license": "MIT",
  "engines": {
    "python": ">=3.6",
    "node": ">=12.0.0"
  },
  "requirements": {
    "python": ["Pillow>=8.0.0"]
  }
}